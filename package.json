{
  "name": "war3-re",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "board:refresh": "node ./scripts/generate-dual-lane-board.mjs",
    "board:start": "./scripts/board-stack.sh start",
    "board:stop": "./scripts/board-stack.sh stop",
    "board:restart": "./scripts/board-stack.sh restart",
    "board:status": "./scripts/board-stack.sh status",
    "board:daemon:start": "./scripts/dual-lane-board-daemon.sh start",
    "board:daemon:stop": "./scripts/dual-lane-board-daemon.sh stop",
    "board:daemon:restart": "./scripts/dual-lane-board-daemon.sh restart",
    "board:daemon:status": "./scripts/dual-lane-board-daemon.sh status",
    "board:server:start": "./scripts/board-server-daemon.sh start",
    "board:server:stop": "./scripts/board-server-daemon.sh stop",
    "board:server:restart": "./scripts/board-server-daemon.sh restart",
    "board:server:status": "./scripts/board-server-daemon.sh status",
    "lane:setup": "node ./scripts/dual-lane-companion.mjs setup",
    "lane:task": "node ./scripts/dual-lane-companion.mjs task",
    "lane:refresh": "node ./scripts/dual-lane-companion.mjs refresh --json",
    "lane:status": "node ./scripts/dual-lane-companion.mjs status",
    "lane:result": "node ./scripts/dual-lane-companion.mjs result",
    "lane:cancel": "node ./scripts/dual-lane-companion.mjs cancel",
    "feed:codex": "./scripts/codex-watch-feed.sh check",
    "feed:glm": "./scripts/glm-watch-feed.sh check",
    "queue:refill": "node ./scripts/queue-refill.mjs --lane all --apply",
    "queue:refill:status": "node ./scripts/queue-refill.mjs --lane all --json",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "test:closeout": "./scripts/run-runtime-tests.sh tests/closeout.spec.ts --reporter=list",
    "test:lane-feed": "node --test tests/lane-feed.spec.mjs",
    "test:first-five": "./scripts/run-runtime-tests.sh tests/first-five-minutes.spec.ts --reporter=list",
    "preview:ci": "vite preview --host 127.0.0.1 --port 4173",
    "test:runtime": "./scripts/run-runtime-suite.sh",
    "test:runtime:single": "./scripts/run-runtime-tests.sh tests/closeout.spec.ts tests/first-five-minutes.spec.ts tests/command-regression.spec.ts tests/combat-control-regression.spec.ts tests/command-card-state-regression.spec.ts tests/resource-supply-regression.spec.ts tests/mining-saturation-regression.spec.ts tests/rally-contract-regression.spec.ts tests/unit-presence-regression.spec.ts tests/unit-visibility-regression.spec.ts tests/pathing-footprint-regression.spec.ts tests/selection-input-regression.spec.ts tests/ai-economy-regression.spec.ts tests/asset-pipeline-regression.spec.ts tests/building-agency-regression.spec.ts tests/death-cleanup-regression.spec.ts tests/construction-lifecycle-regression.spec.ts tests/static-defense-regression.spec.ts tests/m4-player-reported-issues.spec.ts --reporter=list",
    "test:command": "./scripts/run-runtime-tests.sh tests/command-regression.spec.ts --reporter=list",
    "test:command-card": "./scripts/run-runtime-tests.sh tests/command-card-state-regression.spec.ts --reporter=list",
    "test:resource": "./scripts/run-runtime-tests.sh tests/resource-supply-regression.spec.ts --reporter=list",
    "test:mining-saturation": "./scripts/run-runtime-tests.sh tests/mining-saturation-regression.spec.ts --reporter=list",
    "test:rally": "./scripts/run-runtime-tests.sh tests/rally-contract-regression.spec.ts --reporter=list",
    "test:unit-presence": "./scripts/run-runtime-tests.sh tests/unit-presence-regression.spec.ts --reporter=list",
    "test:visibility": "./scripts/run-runtime-tests.sh tests/unit-visibility-regression.spec.ts --reporter=list",
    "test:selection": "./scripts/run-runtime-tests.sh tests/selection-input-regression.spec.ts --reporter=list",
    "test:pathing": "./scripts/run-runtime-tests.sh tests/pathing-footprint-regression.spec.ts --reporter=list",
    "test:ai": "./scripts/run-runtime-tests.sh tests/ai-economy-regression.spec.ts --reporter=list",
    "test:assets": "./scripts/run-runtime-tests.sh tests/asset-pipeline-regression.spec.ts --reporter=list",
    "test:building-agency": "./scripts/run-runtime-tests.sh tests/building-agency-regression.spec.ts --reporter=list",
    "test:death-cleanup": "./scripts/run-runtime-tests.sh tests/death-cleanup-regression.spec.ts --reporter=list",
    "test:construction": "./scripts/run-runtime-tests.sh tests/construction-lifecycle-regression.spec.ts --reporter=list",
    "test:static-defense": "./scripts/run-runtime-tests.sh tests/static-defense-regression.spec.ts --reporter=list",
    "test:combat-control": "./scripts/run-runtime-tests.sh tests/combat-control-regression.spec.ts --reporter=list",
    "test:queue-refill": "node --test tests/queue-refill.spec.mjs",
    "test:m2": "./scripts/run-runtime-tests.sh tests/construction-lifecycle-regression.spec.ts tests/static-defense-regression.spec.ts tests/command-card-state-regression.spec.ts tests/unit-presence-regression.spec.ts tests/combat-control-regression.spec.ts --reporter=list",
    "test:m3-scale": "./scripts/run-runtime-tests.sh tests/m3-scale-measurement.spec.ts --reporter=list"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "three": "^0.174.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@types/three": "^0.174.0",
    "playwright": "^1.59.1",
    "typescript": "~5.7.0",
    "vite": "^6.2.0"
  }
}
